# .env — CloudRISK (local)

# -------- API --------
USE_LOCAL_STORE=1
PROJECT_ID=cloudrisk-local
SECRET_KEY=dev-secret-key-change-in-prod
PORT=8080

# -------- Emuladores (solo si USE_LOCAL_STORE=0) --------
FIRESTORE_EMULATOR_HOST=firestore-emulator:8200
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085

#Dato importante 

# LEE ESTO ANTES DE ARRANCAR EN LOCAL CON `docker compose up` O `python main.py`:    <------------------------------------------------------------------

# USE_LOCAL_STORE — modo de persistencia del backend.
# "1" = almacén en RAM (dict de Python que imita Firestore). Siembra 87 barrios
#       y 4 jugadores demo al arrancar. Se borra al reiniciar. Sin GCP, sin Docker,
#       sin credenciales. Ideal para desarrollo local y tests.
# "0" = usa Firestore (emulador en local, real en GCP).



# Qué pasa cuando arranca con USE_LOCAL_STORE=1

# main.py detecta el flag y siembra datos automáticamente:
# Las 87 zonas de Valencia (barrios con sus coordenadas).
# 4 jugadores demo leídos de data/players.json para poder hacer login sin registrarse.
# El endpoint /turn/setup se vuelve público (sin token) para que puedas juguetear sin autenticación interna.
# Pub/Sub también se sustituye: los "mensajes publicados" se guardan en una lista _pubsub_log en memoria en vez de salir a un topic real.

# Qué pasa cuando arranca con USE_LOCAL_STORE=0

# main.py detecta el flag y se conecta a Firestore (emulador o real según el entorno).

# USE_LOCAL_STORE — modo de persistencia del backend.
# "0" = usa Firestore real. En local se conecta al emulador (contenedor Docker
#       en localhost:8200, definido en docker-compose.yml). En GCP se conecta
#       a la Firestore real del proyecto. Los datos persisten entre reinicios
#       del backend (mientras viva el emulador o el proyecto GCP).

