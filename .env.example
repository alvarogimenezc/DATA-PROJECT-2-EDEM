# .env.example — CloudRISK environment variables reference.
# Copy to .env (gitignored) and adjust as needed.
# Every variable here has a sensible default in code; override only when necessary.

# -------- API (cloudrisk_api) --------

# Use an in-memory store instead of Firestore. Seeds 87 Valencia zones on startup.
# Set to "1" for local dev without emulators. Leave unset or "0" in production.
USE_LOCAL_STORE=1

# GCP project ID used by Firestore / Pub/Sub clients.
PROJECT_ID=cloudrisk-local

# JWT signing secret. MUST be a strong random string in production.
SECRET_KEY=dev-secret-key-change-in-prod

# Emulator endpoints (used only when USE_LOCAL_STORE is unset/0 but emulators are running).
# Defaults match docker-compose.yml service names.
FIRESTORE_EMULATOR_HOST=firestore-emulator:8200
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085

# Port the API binds to inside the container.
PORT=8080

# -------- Dashboard (Streamlit) --------

# "local" = read metrics from local store / filesystem. "bigquery" = read from BigQuery.
METRICS_SOURCE=local

# BigQuery dataset (only if METRICS_SOURCE=bigquery).
BIGQUERY_DATASET=cloudrisk_metrics

# -------- Frontend (Vite) --------

# Optional: override the API base URL injected at build time. Normally unset, because
# Vite's dev proxy (vite.config.js) handles routing /api/v1 -> API in development.
# VITE_API_URL=https://api.your-domain.com

# -------- CloudRISK adapter (team backend integration) --------

# Optional. When set, our backend proxies a few endpoints to the team
# backend (alvarogimenezc/DATA-PROJECT-2-EDEM): /state/locations,
# /state/player/{id}, /actions/place. Leave unset to use the local store.
# CLOUDRISK_API_URL=https://cloudrisk-api-xxxxx.a.run.app

# -------- Deployment only (not needed locally) --------

# Service account key for GCP deployment (do NOT commit).
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
