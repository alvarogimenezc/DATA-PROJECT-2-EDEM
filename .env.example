# .env.example — CloudRISK
# Copia este fichero a .env y ajusta si hace falta.
# Todas las variables tienen defaults sensatos; en local normalmente no toca nada.

# -------- API --------

# "1" = usa almacén en memoria (siembra 87 barrios al arrancar, sin emuladores).
# "0" o vacío = usa Firestore/Pub/Sub (emuladores en local, reales en GCP).
USE_LOCAL_STORE=1

# ID del proyecto GCP. En local cualquier string vale.
PROJECT_ID=cloudrisk-local

# Secreto para firmar tokens JWT. Cámbialo por algo aleatorio en producción.
SECRET_KEY=dev-secret-key-change-in-prod

# Puerto del API dentro del contenedor.
PORT=8080

# -------- Emuladores (solo si USE_LOCAL_STORE=0) --------
# Los nombres coinciden con los servicios de docker-compose.yml.
FIRESTORE_EMULATOR_HOST=firestore-emulator:8200
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
