# Multi-stage so the same Dockerfile produces TWO images: one for the air
# quality ingestor and one for the weather ingestor. Same base layer, same
# requirements, two CMDs.
#
# Build:
#   docker build -t cloudrisk/air-ingestor     --target air     weather_airq/
#   docker build -t cloudrisk/weather-ingestor --target weather weather_airq/
FROM python:3.12-slim AS base
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

FROM base AS air
COPY calidad_aire.py .
CMD ["python", "-u", "calidad_aire.py"]

FROM base AS weather
COPY clima.py .
CMD ["python", "-u", "clima.py"]
